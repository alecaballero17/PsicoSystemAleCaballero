# ==============================================================================
# CONFIGURACIÓN DE ENTORNO - PsicoSystem SI2
# Instrucciones: Copie este archivo como '.env' y complete los valores.
# ==============================================================================

# --- SEGURIDAD CORE ---
SECRET_KEY='su-clave-secreta-aqui-muy-segura'
DEBUG=True

# --- BASE DE DATOS (PostgreSQL) ---
# Use DB_PASSWORD si se conecta localmente con la URL por defecto en settings.py
DB_PASSWORD='su_password_de_postgres'
# O defina la URL completa (Recomendado para Producción/Render)
# DATABASE_URL='postgres://usuario:password@host:puerto/nombre_db'

# --- RED E INTEROPERABILIDAD ---
# IP de su máquina local para conexión desde Web y Mobile (Obtener con ipconfig/ifconfig)
SERVER_IP=127.0.0.1
ALLOWED_HOSTS='localhost,127.0.0.1,psicosystem-app.onrender.com'
CORS_ALLOW_ALL_ORIGINS=True

# --- COMUNICACIONES (Email) ---
# Por defecto se usa la consola en desarrollo.
EMAIL_BACKEND='django.core.mail.backends.console.EmailBackend'
EMAIL_HOST=''
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=''
EMAIL_HOST_PASSWORD=''

# --- INTELIGENCIA ARTIFICIAL (Gemini) ---
GEMINI_API_KEY='tu-api-key-de-google-gemini-aqui'
